{
  "manifest_version": 3,
  "name": "Yoink!",
  "version": "0.1.0",
  "description": "Extract DOM, computed styles, and layout data from any page for Figma reconstruction.",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Yoink!"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"]
}
